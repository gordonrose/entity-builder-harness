{
  "name": "entity-builder-harness",
  "private": true,
  "workspaces": [
    "packages/*",
    "platform/*"
  ],
  "scripts": {
    "chat": "bash scripts/00.chat/command/dispatcher/script.sh",
    "chat:list": "bash scripts/00.chat/command/dispatcher/script.sh list",
    "chat:new": "bash scripts/00.chat/command/dispatcher/script.sh new",
    "chat:open-window": "bash scripts/00.chat/command/dispatcher/script.sh open-window",
    "chat:download-repo": "bash scripts/00.chat/command/dispatcher/script.sh download-repo",
    "chat:download-repo-diff": "bash scripts/00.chat/command/dispatcher/script.sh download-repo-diff",
    "chat:close": "bash scripts/00.chat/command/dispatcher/script.sh close",
    "chat:audit-bootstrap": "bash scripts/00.chat/bootstrap/audit-chat-bootstrap-file-set/script.sh",
    "chat:audit-layer-migration": "bash scripts/00.chat/migration/audit-chat-layer-migration/script.sh",
    "chat:cleanup-empty-branches": "bash scripts/00.chat/git/cleanup-empty-chat-branches/script.sh",
    "chat:commit-log-summary": "bash scripts/00.chat/reporting/generate-commit-log-summary/script.sh",
    "chat:record-main-refresh-conflict": "bash scripts/00.chat/session-log/record-main-refresh-conflict/script.sh",
    "chat:report-workspaces": "bash scripts/00.chat/reporting/report-chat-workspaces/script.sh",
    "chat:smoke-package-scripts": "bash scripts/00.chat/command/package-scripts/smoke-test.sh",
    "rag:service": "bash scripts/01.harness/run-governed-script.sh --approved-action scripts/02.rag-rulebook/run-local-service/script.sh",
    "rag:service:smoke": "bash scripts/01.harness/run-governed-script.sh --approved-action scripts/02.rag-rulebook/run-local-service/smoke-test.sh",
    "rag:image:build": "bash scripts/01.harness/run-governed-script.sh --approved-action scripts/02.rag-rulebook/build-service-image/script.sh",
    "rag:image:smoke": "bash scripts/01.harness/run-governed-script.sh --approved-action scripts/02.rag-rulebook/smoke-test-service-image/script.sh",
    "core:check": "npm run core:typecheck && npm run core:test && node packages/core/tests/core-boundaries.test.mjs",
    "core:test": "tsc -p packages/core/tsconfig.runtime-test.json && node packages/core/tests/run-runtime-tests.mjs",
    "core:typecheck": "tsc -p packages/core/tsconfig.check.json",
    "platform:contracts:boundary": "node platform/contracts/tests/platform-contracts-boundaries.test.mjs",
    "platform:contracts:build": "tsc -p platform/contracts/tsconfig.json",
    "platform:contracts:check": "npm run platform:contracts:typecheck && npm run platform:contracts:build && npm run platform:contracts:test && npm run platform:contracts:boundary",
    "platform:contracts:test": "tsc -p platform/contracts/tsconfig.runtime-test.json && node platform/contracts/tests/run-runtime-tests.mjs",
    "platform:contracts:typecheck": "tsc -p platform/contracts/tsconfig.check.json",
    "platform:runtime:boundary": "node platform/runtime/tests/platform-runtime-boundaries.test.mjs",
    "platform:runtime:build": "tsc -p platform/runtime/tsconfig.json",
    "platform:runtime:check": "npm run platform:runtime:typecheck && npm run platform:runtime:build && npm run platform:runtime:test && npm run platform:runtime:boundary",
    "platform:runtime:test": "tsc -p platform/runtime/tsconfig.runtime-test.json && node platform/runtime/tests/run-runtime-tests.mjs",
    "platform:runtime:typecheck": "tsc -p platform/runtime/tsconfig.check.json",
    "platform:server:boundary": "node platform/server/tests/platform-server-boundaries.test.mjs",
    "platform:server:build": "tsc -p platform/server/tsconfig.json",
    "platform:server:check": "npm run platform:server:typecheck && npm run platform:server:build && npm run platform:server:test && npm run platform:server:boundary",
    "platform:server:test": "tsc -p platform/server/tsconfig.runtime-test.json && node platform/server/tests/run-runtime-tests.mjs",
    "platform:server:typecheck": "tsc -p platform/server/tsconfig.check.json",
    "platform:testing:boundary": "node platform/testing/tests/platform-testing-boundaries.test.mjs",
    "platform:testing:build": "tsc -p platform/testing/tsconfig.json",
    "platform:testing:check": "npm run platform:testing:typecheck && npm run platform:testing:build && npm run platform:testing:test && npm run platform:testing:boundary",
    "platform:testing:test": "tsc -p platform/testing/tsconfig.runtime-test.json && node platform/testing/tests/run-runtime-tests.mjs",
    "platform:testing:typecheck": "tsc -p platform/testing/tsconfig.check.json",
    "platform:workers:boundary": "node platform/workers/tests/platform-workers-boundaries.test.mjs",
    "platform:workers:build": "tsc -p platform/workers/tsconfig.json",
    "platform:workers:check": "npm run platform:workers:typecheck && npm run platform:workers:build && npm run platform:workers:test && npm run platform:workers:boundary",
    "platform:workers:test": "tsc -p platform/workers/tsconfig.runtime-test.json && node platform/workers/tests/run-runtime-tests.mjs",
    "platform:workers:typecheck": "tsc -p platform/workers/tsconfig.check.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "5.9.3"
  }
}
