# Allow Codex to run the harness-governed script runner without repeated
# manual approval. The runner owns the actual script allowlist.
prefix_rule(
    pattern = ["bash", "scripts/01.harness/run-governed-script.sh"],
    decision = "allow",
    justification = "Run only scripts permitted by the harness governed-script runner.",
    match = [
        "bash scripts/01.harness/run-governed-script.sh --list",
        "bash scripts/01.harness/run-governed-script.sh scripts/00.chat/worktree/check-write-location/script.sh",
        "bash scripts/01.harness/run-governed-script.sh --approved-action scripts/00.chat/session-log/record-chat-commit/script.sh abc1234 message summary",
        "bash scripts/01.harness/run-governed-script.sh --approved-action scripts/00.chat/session-log/checkpoint-chat-session-log/script.sh",
        "bash scripts/01.harness/run-governed-script.sh --approved-action scripts/01.harness/artifact-metadata/backfill-v2-headers/script.sh --batch 4",
    ],
    not_match = [
        "bash scripts/00.chat/session-log/checkpoint-chat-session-log/script.sh",
        "bash scripts/00.chat/session-log/record-chat-commit/script.sh abc1234 message summary",
        "bash -lc scripts/01.harness/run-governed-script.sh --list",
        "sh scripts/01.harness/run-governed-script.sh --list",
    ],
)
