{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "incremental": false,
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "noEmit": false,
    "outDir": "../../.cache/platform-observability-runtime",
    "baseUrl": "../..",
    "paths": {
      "@kanbien/core": [
        "packages/core/src/index.ts"
      ],
      "@kanbien/core/*": [
        "packages/core/src/*/index.ts"
      ]
    },
    "rootDir": "../..",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "tests/*-runtime.test.ts"
  ]
}
