{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "incremental": false,
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "noEmit": false,
    "outDir": "../../.cache/platform-shell-image-build",
    "baseUrl": "../..",
    "paths": {
      "@kanbien/core": [
        "packages/core/src/index.ts"
      ],
      "@kanbien/core/*": [
        "packages/core/src/*/index.ts"
      ],
      "@kanbien/platform-contracts": [
        "platform/contracts/src/index.ts"
      ],
      "@kanbien/platform-config": [
        "platform/config/src/index.ts"
      ],
      "@kanbien/platform-health": [
        "platform/health/src/index.ts"
      ],
      "@kanbien/platform-observability": [
        "platform/observability/src/index.ts"
      ],
      "@kanbien/platform-runtime": [
        "platform/runtime/src/index.ts"
      ],
      "@kanbien/platform-security": [
        "platform/security/src/index.ts"
      ]
    },
    "rootDir": "../..",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "../config/src/**/*.ts",
    "../contracts/src/**/*.ts",
    "../health/src/**/*.ts",
    "../observability/src/**/*.ts",
    "../runtime/src/**/*.ts",
    "../security/src/**/*.ts"
  ]
}
